# 100 Miles, 100 Days — environment variables
#
# Copy this file to `.env` for local dev, and set the same vars in
# Netlify → Site settings → Environment variables for production.
#
# If these are unset, the app falls back to localStorage + mock data
# (the prototype behavior). Setting them switches to the real Supabase backend.

# From Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key...

# Optional — Sentry for client error monitoring (sentry.io free tier)
# VITE_SENTRY_DSN=https://...@...ingest.sentry.io/...
